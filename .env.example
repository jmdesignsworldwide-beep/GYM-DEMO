# Supabase — copia estos valores desde tu proyecto de Supabase (Settings → API)
# Estas dos pueden ser públicas (van con prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOLO servidor — marcar "Sensitive" en Vercel, NUNCA con prefijo NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=
